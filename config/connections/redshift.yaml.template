# Amazon Redshift connection
# Copy to redshift.yaml and fill in your values
name: Redshift Warehouse
type: redshift
enabled: false
settings:
  host: my-cluster.xxxx.eu-north-1.redshift.amazonaws.com
  port: 5439
  database: analytics
  schema: public
  user_from_secret: redshift/prod-creds  # AWS Secrets Manager secret name
  region: eu-north-1
