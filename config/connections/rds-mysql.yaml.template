# Amazon RDS MySQL / Aurora MySQL connection
# Copy to rds-mysql.yaml and fill in your values
# Deploy Aurora: ./scripts/deploy-rds.sh --auto
name: RDS MySQL
type: rds_mysql
enabled: true
settings:
  host: YOUR_CLUSTER_ENDPOINT.eu-north-1.rds.amazonaws.com
  port: 3306
  database: analyst_db
  user_from_secret: ai-rds-aurora/aurora-credentials  # AWS Secrets Manager secret name
  region: eu-north-1
